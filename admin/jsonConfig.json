{
  "i18n": true,
  "type": "panel",
  "items": {
    "host": {
      "type": "text",
      "label": "Device IP or hostname",
      "validator": "!!data.host && /^[a-zA-Z0-9]([a-zA-Z0-9.\\-]*[a-zA-Z0-9])?$/.test(data.host)",
      "validatorErrorText": "Enter a valid IP address or hostname (no http://, no spaces)",
      "validatorNoSaveOnError": true,
      "xs": 12,
      "sm": 12,
      "md": 4,
      "lg": 4,
      "xl": 4
    },
    "aliveTimeout": {
      "newLine": true,
      "type": "number",
      "label": "Alive timeout",
      "help": "ms",
      "default": 30000,
      "min": 1000,
      "max": 600000,
      "xs": 12,
      "sm": 6,
      "md": 2,
      "lg": 2,
      "xl": 2
    },
    "reconnectInterval": {
      "type": "number",
      "label": "Reconnect interval",
      "help": "ms - should be >= Alive timeout",
      "default": 30000,
      "min": 1000,
      "max": 600000,
      "validator": "data.reconnectInterval >= data.aliveTimeout",
      "validatorErrorText": "Reconnect interval should be at least the Alive timeout",
      "xs": 12,
      "sm": 6,
      "md": 2,
      "lg": 2,
      "xl": 2
    },
    "protocol": {
      "newLine": true,
      "type": "select",
      "options": [
        {
          "label": "CoAP",
          "value": "coap"
        },
        {
          "label": "HTTP",
          "value": "http"
        }
      ],
      "noTranslation": true,
      "label": "Communication protocol",
      "default": "coap",
      "xs": 12,
      "sm": 12,
      "md": 4,
      "lg": 4,
      "xl": 4
    }
  }
}